# ─────────────────────────────────────────────────────────────────────────────
# REPCONNECT — environment variable reference
#
# Copy this file to .env (root) for Docker Compose and to
# backend/repconnect/.env for local development, then fill in real values.
#
# Generate strong secrets with:
#   python -c "import secrets; print(secrets.token_hex(64))"
# ─────────────────────────────────────────────────────────────────────────────


# ── Docker Compose secrets (root .env only) ───────────────────────────────────

# Django signing key — must be long, random, and kept private.
# Changing this invalidates all existing JWT tokens and CSRF tokens.
DJANGO_SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_64

# MySQL credentials
MYSQL_ROOT_PASSWORD=CHANGE_ME_strong_root_password
MYSQL_PASSWORD=CHANGE_ME_strong_user_password


# ── Django settings (backend/repconnect/.env for local dev) ───────────────────

# Same value as DJANGO_SECRET_KEY above when running locally outside Docker.
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_64

# True for local development, False in production / Docker.
DEBUG=True

# Comma-separated list of allowed hostnames (no spaces).
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated allowed CORS origins (must include the frontend URL).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Comma-separated CSRF trusted origins (must match your frontend URL).
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000


# ── Database connection ───────────────────────────────────────────────────────

# Django database backend.
DB_ENGINE=django.db.backends.mysql

# Database name.
DB_NAME=repconnect

# Database user (must match MYSQL_USER in Docker Compose).
DB_USER=repconnect

# Database password (must match MYSQL_PASSWORD above).
DB_PASSWORD=CHANGE_ME_strong_user_password

# Host: 'localhost' for local dev (MySQL mapped on DB_PORT), 'db' inside Docker.
DB_HOST=localhost

# Port: 3311 for local dev (mapped host port), 3306 inside Docker network.
DB_PORT=3311


# ── MIS Ticket — n8n webhook ─────────────────────────────────────────────────

# Full URL to the n8n webhook that handles MIS chat messages.
# Leave empty to disable the MIS chat relay.
N8N_WEBHOOK_URL=


# ── Security (production only) ────────────────────────────────────────────────

# Seconds for HSTS max-age header. Set to 63072000 (2 years) once HTTPS is
# confirmed stable. Leave at 0 while still on HTTP to avoid locking out browsers.
SECURE_HSTS_SECONDS=0

# Redirect all HTTP requests to HTTPS. Enable only after TLS is confirmed working.
SECURE_SSL_REDIRECT=False


# ── Logging ───────────────────────────────────────────────────────────────────

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Directory where rotating log files are written.
# Defaults to backend/repconnect/logs/ if not set.
# LOG_DIR=/var/log/repconnect
